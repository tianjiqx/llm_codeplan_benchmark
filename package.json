{
  "name": "llm_codeplan_benchmark",
  "version": "1.0.0",
  "description": "LLM 提供商基准性能测试 - TPS 和并发测试",
  "type": "module",
  "scripts": {
    "test": "bun test --timeout 120000",
    "test:tps": "bun test src/tps.test.ts --timeout 120000",
    "test:concurrent": "bun test src/concurrent.test.ts --timeout 300000",
    "benchmark": "bun run src/benchmark.ts",
    "benchmark:tps": "bun run src/benchmark.ts --mode=tps",
    "benchmark:concurrent": "bun run src/benchmark.ts --mode=concurrent",
    "benchmark:all": "bun run src/benchmark.ts --mode=all",
    "benchmark:bailian": "bun run src/benchmark.ts --provider=bailian-coding-plan",
    "benchmark:volcengine": "bun run src/benchmark.ts --provider=volcengine",
    "benchmark:glm": "bun run src/benchmark.ts --provider=glm-codeplan"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3",
    "@ai-sdk/openai-compatible": "^2",
    "ai": "^6",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.2"
  }
}